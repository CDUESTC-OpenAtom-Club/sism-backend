{
  "scenarios": [
    {
      "id": "indicator-distribution",
      "name": "指标创建与下发流程",
      "description": "测试战略部门创建指标并下发到职能部门的完整流程",
      "actor": "strategic",
      "steps": [
        {
          "action": "create_indicator",
          "description": "创建草稿指标",
          "expectedStatus": "DRAFT",
          "api": "POST /indicators"
        },
        {
          "action": "distribute_indicator",
          "description": "提交下发审批",
          "expectedStatus": "PENDING",
          "api": "POST /indicators/{id}/distribute"
        },
        {
          "action": "approve_distribution",
          "description": "审批通过下发",
          "expectedStatus": "DISTRIBUTED",
          "api": "POST /workflow/instances/{id}/approve"
        }
      ]
    },
    {
      "id": "indicator-split",
      "name": "指标拆分流程",
      "description": "测试职能部门接收父指标并拆分为子指标下发给学院",
      "actor": "functional",
      "prerequisites": ["indicator-distribution"],
      "steps": [
        {
          "action": "get_parent_indicator",
          "description": "获取父指标详情",
          "api": "GET /indicators/{id}"
        },
        {
          "action": "create_child_indicators",
          "description": "创建子指标",
          "api": "POST /indicators",
          "expectedParentId": "{parent_indicator_id}"
        },
        {
          "action": "distribute_children",
          "description": "下发子指标",
          "api": "POST /indicators/{id}/distribute"
        }
      ]
    },
    {
      "id": "report-submission",
      "name": "学院进度填报流程",
      "description": "测试学院填报进度并提交审批的完整流程",
      "actor": "college",
      "prerequisites": ["indicator-split"],
      "steps": [
        {
          "action": "create_report",
          "description": "创建填报（草稿）",
          "expectedStatus": "DRAFT",
          "api": "POST /reports"
        },
        {
          "action": "submit_report",
          "description": "提交审批",
          "expectedStatus": "PENDING",
          "api": "POST /reports/{id}/submit"
        }
      ]
    },
    {
      "id": "multi-level-approval",
      "name": "多级审批流程",
      "description": "测试填报的学院审批和职能部门审批",
      "actor": "workflow",
      "prerequisites": ["report-submission"],
      "steps": [
        {
          "action": "college_approve",
          "description": "学院内部审批",
          "level": 1,
          "api": "POST /workflow/instances/{id}/approve"
        },
        {
          "action": "functional_approve",
          "description": "职能部门审批",
          "level": 2,
          "api": "POST /workflow/instances/{id}/approve"
        }
      ]
    },
    {
      "id": "approval-rejection",
      "name": "审批驳回流程",
      "description": "测试审批驳回并回退到上一节点",
      "actor": "workflow",
      "steps": [
        {
          "action": "submit_for_approval",
          "description": "提交审批",
          "api": "POST /reports/{id}/submit"
        },
        {
          "action": "reject_with_comment",
          "description": "驳回并填写意见",
          "api": "POST /workflow/instances/{id}/reject",
          "requireComment": true
        },
        {
          "action": "verify_status_rollback",
          "description": "验证状态回退到草稿",
          "expectedStatus": "DRAFT"
        }
      ]
    },
    {
      "id": "approval-timeline",
      "name": "审批时间轴测试",
      "description": "测试审批时间轴的完整性和准确性",
      "actor": "workflow",
      "steps": [
        {
          "action": "create_workflow",
          "description": "创建工作流实例",
          "api": "POST /workflow/instances"
        },
        {
          "action": "execute_steps",
          "description": "执行所有审批步骤",
          "api": "POST /workflow/instances/{id}/approve"
        },
        {
          "action": "get_timeline",
          "description": "获取审批时间轴",
          "api": "GET /workflow/instances/{id}/timeline"
        },
        {
          "action": "verify_timeline_integrity",
          "description": "验证时间轴完整性",
          "verifyFields": ["operator", "timestamp", "action", "comment"]
        }
      ]
    },
    {
      "id": "report-withdrawal",
      "name": "填报撤回测试",
      "description": "测试提交后撤回填报的功能",
      "actor": "college",
      "steps": [
        {
          "action": "submit_report",
          "description": "提交填报",
          "api": "POST /reports/{id}/submit"
        },
        {
          "action": "withdraw_report",
          "description": "撤回填报",
          "api": "POST /reports/{id}/withdraw"
        },
        {
          "action": "verify_withdrawal",
          "description": "验证撤回后状态",
          "expectedStatus": "DRAFT"
        }
      ]
    },
    {
      "id": "parent-child-relationship",
      "name": "父子指标关系测试",
      "description": "测试父子指标的关系查询",
      "actor": "analytics",
      "steps": [
        {
          "action": "get_parent_indicator",
          "description": "获取父指标",
          "api": "GET /indicators/{id}"
        },
        {
          "action": "get_children",
          "description": "获取子指标列表",
          "api": "GET /indicators/{id}/children"
        },
        {
          "action": "verify_relationship",
          "description": "验证父子关系正确性"
        },
        {
          "action": "verify_no_progress_aggregation",
          "description": "验证没有进度聚合（仅关系查询）"
        }
      ]
    },
    {
      "id": "period-identification",
      "name": "周期标识测试",
      "description": "测试所有数据都正确绑定周期标识",
      "actor": "analytics",
      "steps": [
        {
          "action": "create_indicator_with_period",
          "description": "创建带周期的指标",
          "api": "POST /indicators"
        },
        {
          "action": "create_report_with_period",
          "description": "创建带周期的填报",
          "api": "POST /reports"
        },
        {
          "action": "verify_period_field",
          "description": "验证周期字段存在且正确"
        }
      ]
    },
    {
      "id": "data-change-tracking",
      "name": "数据变更追踪测试",
      "description": "测试数据变更的记录和对比功能",
      "actor": "workflow",
      "steps": [
        {
          "action": "create_initial_data",
          "description": "创建初始数据",
          "api": "POST /reports"
        },
        {
          "action": "modify_data_by_approver",
          "description": "审批人修改数据",
          "api": "PUT /reports/{id}"
        },
        {
          "action": "get_change_history",
          "description": "获取变更历史",
          "api": "GET /workflow/instances/{id}/history"
        },
        {
          "action": "verify_change_record",
          "description": "验证变更记录包含字段、原值、新值"
        }
      ]
    }
  ]
}
