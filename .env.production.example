# =============================================================================
# SISM Backend - 生产环境配置示例
# Production Environment Configuration Example
# =============================================================================
# 
# 重要提示 (Important Notes):
# 1. 此文件仅作为生产环境配置的参考模板
# 2. 实际部署时，请根据具体环境调整配置
# 3. 所有敏感信息必须使用强密钥和密码
# 4. 建议使用密钥管理服务（如 AWS Secrets Manager、HashiCorp Vault）
# 
# 使用方法 (Usage):
# cp .env.production.example .env.production
# 编辑 .env.production 填写实际值
# 
# =============================================================================

# -----------------------------------------------------------------------------
# 必需配置 (Required Configuration)
# -----------------------------------------------------------------------------

# JWT 签名密钥 (JWT Signing Secret Key)
# ⚠️ 生产环境必须使用强随机密钥
# ⚠️ 使用以下命令生成: openssl rand -base64 32
# ⚠️ 不同环境使用不同密钥
# ⚠️ 定期更换（建议每 3-6 个月）
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_KEY_GENERATED_BY_OPENSSL

# 数据库连接 URL (Database Connection URL)
# 生产环境建议:
# - 使用专用数据库服务器
# - 启用 SSL 连接
# - 使用连接池
# 示例: jdbc:postgresql://prod-db.internal:5432/strategic_prod?stringtype=unspecified&ssl=true&sslmode=require
DB_URL=jdbc:postgresql://YOUR_DB_HOST:5432/YOUR_DB_NAME?stringtype=unspecified&ssl=true&sslmode=require

# 数据库用户名 (Database Username)
# ⚠️ 不要使用 postgres 超级用户
# ⚠️ 使用专用应用用户，遵循最小权限原则
DB_USERNAME=sism_prod

# 数据库密码 (Database Password)
# ⚠️ 必须使用强密码
# ⚠️ 定期更换密码
# ⚠️ 建议使用密钥管理服务
DB_PASSWORD=REPLACE_WITH_STRONG_DATABASE_PASSWORD

# -----------------------------------------------------------------------------
# JWT 配置 (JWT Configuration)
# -----------------------------------------------------------------------------

# JWT Token 有效期 (毫秒)
# 生产环境建议: 15分钟 - 1小时
# 更短的有效期更安全，但用户需要更频繁地刷新 token
JWT_EXPIRATION=900000

# JWT Refresh Token 有效期 (毫秒)
# 生产环境建议: 7-30天
JWT_REFRESH_EXPIRATION=604800000

# 每用户最大会话数
# 限制单个用户同时登录的设备数量
JWT_MAX_SESSIONS=5

# -----------------------------------------------------------------------------
# 服务器配置 (Server Configuration)
# -----------------------------------------------------------------------------

# 服务器端口
# 默认: 8080
# 如果使用反向代理（Nginx/Apache），通常保持默认值
SERVER_PORT=8080

# -----------------------------------------------------------------------------
# CORS 配置 (CORS Configuration)
# -----------------------------------------------------------------------------

# CORS 允许的源
# ⚠️ 生产环境必须指定具体域名，绝不要使用 *
# ⚠️ 必须包含协议（https://）
# ⚠️ 不要包含尾部斜杠
# ⚠️ 多个域名用逗号分隔，不要有空格
# 示例: https://yourdomain.com,https://www.yourdomain.com,https://app.yourdomain.com
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# CORS 允许的 HTTP 方法
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS

# CORS 允许的请求头
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Requested-With,X-Timestamp,X-Signature,X-Idempotency-Key

# CORS 是否允许携带凭证
CORS_ALLOW_CREDENTIALS=true

# CORS 预检请求缓存时间（秒）
CORS_MAX_AGE=3600

# -----------------------------------------------------------------------------
# 日志配置 (Logging Configuration)
# -----------------------------------------------------------------------------

# 日志文件路径
# 确保应用有写入权限
LOG_PATH=/var/log/sism

# 日志级别 - 生产环境建议使用 INFO 或 WARN
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO
LOG_LEVEL_SPRING=WARN
LOG_LEVEL_SECURITY=INFO
LOG_LEVEL_SQL=INFO
LOG_LEVEL_SQL_BINDER=INFO

# -----------------------------------------------------------------------------
# 数据库连接池配置 (Database Connection Pool Configuration)
# -----------------------------------------------------------------------------

# 最大连接数
# 根据应用负载和数据库服务器能力调整
# 计算公式: ((core_count * 2) + effective_spindle_count)
# 生产环境建议: 20-50
DB_POOL_MAX_SIZE=30

# 最小空闲连接数
# 建议设置为最大连接数的 50%
DB_POOL_MIN_IDLE=15

# 连接超时时间（毫秒）
# 生产环境建议: 30秒，容忍短暂的数据库繁忙
DB_CONNECTION_TIMEOUT=30000

# 验证超时时间（毫秒）
DB_VALIDATION_TIMEOUT=3000

# 空闲超时时间（毫秒）
# 连接空闲多久后释放
DB_IDLE_TIMEOUT=600000

# 连接最大生命周期（毫秒）
# 建议设置为数据库服务器超时时间的 90%
# PostgreSQL 默认 8 小时，建议设为 28800000
DB_MAX_LIFETIME=1800000

# 连接泄漏检测阈值（毫秒）
# 生产环境建议禁用（设为 0）以提高性能
# 或设置较大值如 300000（5分钟）
DB_LEAK_DETECTION=0

# -----------------------------------------------------------------------------
# OpenAPI/Swagger 配置 (OpenAPI/Swagger Configuration)
# -----------------------------------------------------------------------------

# Swagger UI 开关
# ⚠️ 生产环境强烈建议禁用，避免 API 信息泄露
SWAGGER_ENABLED=false

# API 文档信息（如果启用 Swagger）
APP_INFO_TITLE=SISM Backend API
APP_INFO_VERSION=1.0.0
APP_INFO_DESCRIPTION=Strategic Indicator Management System - RESTful API Documentation
APP_INFO_CONTACT_NAME=SISM Development Team
APP_INFO_CONTACT_EMAIL=support@yourdomain.com
APP_INFO_LICENSE_NAME=Proprietary
APP_INFO_LICENSE_URL=https://yourdomain.com/license

# -----------------------------------------------------------------------------
# 频率限制配置 (Rate Limit Configuration)
# -----------------------------------------------------------------------------

# 频率限制开关
# ⚠️ 生产环境强烈建议启用，防止 API 滥用和 DDoS 攻击
RATE_LIMIT_ENABLED=true

# 频率限制存储方式
# 生产环境建议使用 redis 支持分布式部署
# 如果是单机部署，可以使用 memory
RATE_LIMIT_STORAGE=redis

# 登录接口频率限制
# 限制登录尝试次数，防止暴力破解
RATE_LIMIT_LOGIN_LIMIT=5
RATE_LIMIT_LOGIN_WINDOW=60

# 通用 API 频率限制
# 限制 API 调用频率，防止滥用
RATE_LIMIT_API_LIMIT=100
RATE_LIMIT_API_WINDOW=60

# -----------------------------------------------------------------------------
# 幂等性配置 (Idempotency Configuration)
# -----------------------------------------------------------------------------

# 幂等性开关
# 启用后可防止重复提交
IDEMPOTENCY_ENABLED=true

# 幂等性键有效期（秒）
# 超时后可以使用相同的键重新提交
IDEMPOTENCY_TTL=300

# -----------------------------------------------------------------------------
# 环境标识 (Environment Identifier)
# -----------------------------------------------------------------------------

# 环境名称
# 用于日志记录和监控
ENVIRONMENT=production

# -----------------------------------------------------------------------------
# 安全检查清单 (Security Checklist)
# -----------------------------------------------------------------------------
# 
# 部署前请确认:
# ✓ JWT_SECRET 使用强随机密钥，不是示例值
# ✓ DB_PASSWORD 使用强密码
# ✓ CORS_ALLOWED_ORIGINS 设置为实际域名，不包含 localhost
# ✓ SWAGGER_ENABLED 设置为 false
# ✓ LOG_LEVEL_* 设置为 INFO 或 WARN
# ✓ RATE_LIMIT_ENABLED 设置为 true
# ✓ 数据库使用 SSL 连接
# ✓ 所有敏感信息使用密钥管理服务
# ✓ 定期备份数据库
# ✓ 配置监控和告警
# 
# -----------------------------------------------------------------------------
