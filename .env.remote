# =============================================================================
# SISM Backend Environment Variables - 本地开发环境
# =============================================================================

# -----------------------------------------------------------------------------
# 数据库配置
# -----------------------------------------------------------------------------
DB_URL=jdbc:postgresql://175.24.139.148:8386/strategic?stringtype=unspecified
DB_USERNAME=postgres
DB_PASSWORD=64378561huaW
DB_HIKARI_MAX_POOL_SIZE=12
DB_HIKARI_MIN_IDLE=0
DB_HIKARI_CONNECTION_TIMEOUT=30000
DB_HIKARI_VALIDATION_TIMEOUT=3000
DB_HIKARI_IDLE_TIMEOUT=30000
DB_HIKARI_MAX_LIFETIME=60000
DB_HIKARI_KEEPALIVE_TIME=30000

# -----------------------------------------------------------------------------
# 服务器配置
# -----------------------------------------------------------------------------
SERVER_PORT=8080
# 不要设置 SERVER_CONTEXT_PATH。
# 控制器已统一使用 /api/v1 前缀；如果这里再配置 /api 或 /api/v1，会导致路径重复或被统一环境读取流程错误覆盖。

# -----------------------------------------------------------------------------
# JWT 配置
# -----------------------------------------------------------------------------
JWT_SECRET=sism-jwt-secret-key-2025-secure-at-least-256-bits-long
JWT_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# -----------------------------------------------------------------------------
# Redis 配置
# -----------------------------------------------------------------------------
REDIS_ENABLED=false

# -----------------------------------------------------------------------------
# 开发工具配置
# -----------------------------------------------------------------------------
SWAGGER_ENABLED=true
FLYWAY_ENABLED=false

# -----------------------------------------------------------------------------
# CORS 配置
# -----------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:3500,https://blackevil.cn,https://www.blackevil.cn
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO
LOG_LEVEL_SQL=WARN
LOG_LEVEL_SQL_BINDER=WARN
